<!DOCTYPE html>
<html lang="en" data-theme="beacon" style="scrollbar-gutter: stable;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <title><%= assigns[:page_title] || "Beacon LiveAdmin" %></title>
    <script>
      (function() {
        var theme = localStorage.getItem("beacon_admin_theme") || "system"
        if (theme === "dark" || (theme === "system" && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.setAttribute("data-theme", "beacon-dark")
        }
      })()
    </script>
    <link rel="stylesheet" href={asset_path(@conn, :css)} />
    <script defer src={asset_path(@conn, :js)}>
    </script>
  </head>
  <body class="h-full antialiased bg-base-200">
    <div class="flex h-full min-h-screen [&>div]:contents">
      <%= @inner_content %>
    </div>
    <button
      id="theme-toggle"
      class="fixed bottom-4 right-4 z-50 btn btn-circle btn-sm bg-base-100 border-base-300 shadow-lg hover:shadow-xl"
      aria-label="Toggle theme"
    >
      <svg data-icon="sun" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
      </svg>
      <svg data-icon="moon" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
      </svg>
      <svg data-icon="system" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
      </svg>
    </button>
    <script>
      (function() {
        var btn = document.getElementById("theme-toggle")
        function applyTheme(theme) {
          if (theme === "dark") {
            document.documentElement.setAttribute("data-theme", "beacon-dark")
          } else if (theme === "light") {
            document.documentElement.setAttribute("data-theme", "beacon")
          } else {
            if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
              document.documentElement.setAttribute("data-theme", "beacon-dark")
            } else {
              document.documentElement.setAttribute("data-theme", "beacon")
            }
          }
        }
        function updateIcons(theme) {
          btn.querySelector("[data-icon=sun]").classList.toggle("hidden", theme !== "light")
          btn.querySelector("[data-icon=moon]").classList.toggle("hidden", theme !== "dark")
          btn.querySelector("[data-icon=system]").classList.toggle("hidden", theme !== "system")
        }
        var current = localStorage.getItem("beacon_admin_theme") || "system"
        updateIcons(current)
        btn.addEventListener("click", function() {
          var c = localStorage.getItem("beacon_admin_theme") || "system"
          var next = c === "light" ? "dark" : c === "dark" ? "system" : "light"
          localStorage.setItem("beacon_admin_theme", next)
          applyTheme(next)
          updateIcons(next)
        })
      })()
    </script>
  </body>
</html>
